{
  "id": "qwen",
  "label": "Qwen / DashScope",
  "icon": "Q",
  "homepage": "https://help.aliyun.com/zh/model-studio/",
  "endpoints": [
    {
      "id": "coding-global",
      "label": "Coding Global",
      "api_type": "openai-chat",
      "default_base_url": "https://coding-intl.dashscope.aliyuncs.com/v1",
      "headers": {
        "User-Agent": "codex-cli/0.80.0 (external, cli)",
        "X-DashScope-AuthType": "openai",
        "X-DashScope-CacheControl": "enable",
        "X-DashScope-UserAgent": "codex-cli/0.80.0 (external, cli)"
      },
      "models": [
        {
          "id": "qwen3.5-plus",
          "label": "qwen3.5-plus"
        },
        {
          "id": "qwen3.6-plus",
          "label": "qwen3.6-plus"
        },
        {
          "id": "qwen3-coder-plus",
          "label": "qwen3-coder-plus"
        },
        {
          "id": "qwen3-coder-next",
          "label": "qwen3-coder-next"
        },
        {
          "id": "qwen3-max-2026-01-23",
          "label": "qwen3-max-2026-01-23"
        },
        {
          "id": "MiniMax-M2.5",
          "label": "MiniMax-M2.5"
        },
        {
          "id": "glm-5",
          "label": "glm-5"
        },
        {
          "id": "glm-4.7",
          "label": "glm-4.7"
        },
        {
          "id": "kimi-k2.5",
          "label": "kimi-k2.5"
        }
      ],
      "auth_modes": [
        {
          "mode": "api_key",
          "label": "Use API key",
          "fields": [
            {
              "name": "api_key",
              "label": "DashScope API key",
              "secret": true,
              "required": true
            }
          ],
          "render": {
            "env": {
              "OPENAI_API_KEY": "{{api_key}}"
            },
            "settings_files": [
              {
                "rel_path": "config.toml",
                "template": "model = \"{{model}}\"\nmodel_provider = \"qwen\"\nmodel_reasoning_effort = \"high\"\ndisable_response_storage = true\n\n[model_providers.qwen]\nname = \"Qwen\"\nbase_url = \"{{base_url}}\"\nwire_api = \"chat\"\nrequires_openai_auth = true\n"
              },
              {
                "rel_path": "auth.json",
                "template": "{\n  \"OPENAI_API_KEY\": \"{{api_key|json}}\"\n}\n"
              }
            ]
          }
        }
      ]
    },
